generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

model Event {
  id            String    @id @default(cuid())
  title         String
  titleEn       String?
  slug          String    @unique
  description   String?   @db.Text
  descriptionEn String?   @db.Text
  date          DateTime
  endDate       DateTime?
  image         String?
  lineup        String?   @db.Text
  lineupEn      String?   @db.Text
  eventType     String?
  featured      Boolean   @default(false)
  published     Boolean   @default(true)
  publishAt     DateTime?
  gallery       Gallery?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([date])
  @@index([published, date])
  @@index([featured, date])
}

model Gallery {
  id         String    @id @default(cuid())
  title      String
  titleEn    String?
  slug       String    @unique
  eventId    String?   @unique
  event      Event?    @relation(fields: [eventId], references: [id])
  coverImage String?
  photos     Photo[]
  date       DateTime
  published  Boolean   @default(true)
  publishAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([published, date])
}

model Photo {
  id          String  @id @default(cuid())
  url         String
  alt         String?
  order       Int     @default(0)
  galleryId   String
  gallery     Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  blurDataUrl String? @db.Text

  @@index([galleryId, order])
}

model Reservation {
  id        String            @id @default(cuid())
  name      String
  email     String
  phone     String
  date      DateTime
  guests    Int
  message   String?           @db.Text
  status    ReservationStatus @default(PENDING)
  eventId   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Page {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  titleEn     String?
  description String?       @db.Text
  /// Internal, non-URL system pages cannot be deleted from admin.
  system      Boolean       @default(false)
  published   Boolean       @default(true)
  showInNav   Boolean       @default(false)
  navLabel    String?
  navLabelEn  String?
  navOrder    Int           @default(0)
  sections    PageSection[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([published, navOrder])
}

model PageSection {
  id         String    @id @default(cuid())
  /// Slug of the owning Page (FK). Kept as column name `page` for backward compat.
  page       String
  pageRef    Page      @relation(fields: [page], references: [slug], onDelete: Cascade)
  type       String
  content    String    @db.Text
  order      Int       @default(0)
  visible    Boolean   @default(true)
  spacing    String?   @db.Text
  publishAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([page, order])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
}

model PageMeta {
  id              String   @id @default(cuid())
  page            String   @unique
  title           String?
  description     String?  @db.Text
  ogImage         String?
  noIndex         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  action    String   // "create", "update", "delete", "publish", "unpublish", "login"
  entity    String   // "event", "gallery", "photo", "reservation", "message", "section", "settings", "user"
  entityId  String?
  details   String?  @db.Text  // JSON
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}
